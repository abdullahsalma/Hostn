{
  "expo": {
    "name": "Hostn",
    "slug": "hostn",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hostn",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#4B0082",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hostn.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Hostn uses your location to show nearby properties.",
        "NSCameraUsageDescription": "Hostn uses the camera to take property and profile photos.",
        "NSPhotoLibraryUsageDescription": "Hostn accesses your photo library to upload images."
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4B0082"
      },
      "package": "com.hostn.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#4B0082"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Hostn to access your photos to upload a profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hostn uses your location to show nearby properties."
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
